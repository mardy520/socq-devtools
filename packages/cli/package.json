{
  "name": "@socq/cli",
  "version": "0.1.0-beta.3",
  "description": "Catalog-driven CLI for SocQ social data APIs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocQAPI/socq-devtools.git",
    "directory": "packages/cli"
  },
  "homepage": "https://docs.socq.ai/integrations/cli",
  "bugs": {
    "url": "https://github.com/SocQAPI/socq-devtools/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {"socq": "./dist/bin.js"},
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {"access": "public"},
  "engines": {"node": ">=20"},
  "dependencies": {
    "@socq/core": "workspace:*",
    "@socq/mcp": "workspace:*"
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
